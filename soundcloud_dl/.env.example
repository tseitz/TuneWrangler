# Required for Phase 1 (playlist extraction via SoundCloud API)
TUNEWRANGLER_SC_PLAYLIST_URL=https://soundcloud.com/your-username/sets/your-playlist
SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret

# SoundCloud identity / download prompts (Phase 2)
TUNEWRANGLER_SC_EMAIL=your@email.com
TUNEWRANGLER_SC_USERNAME=your_soundcloud_username
TUNEWRANGLER_SC_COMMENT=🔥🔥🔥

# Show browser window during Phase 2 (1, true, or yes = headed)
# TUNEWRANGLER_SC_HEADED=1

# Required for Phase 2 (browser-use agent downloads)
OPENAI_API_KEY=your_openai_api_key

# Optional: use Browserless instead of local Playwright
# BROWSERLESS_WS_URL=wss://production-sfo.browserless.io
# BROWSERLESS_TOKEN=your_browserless_token
